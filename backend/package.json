{
  "name": "enterprise-backend",
  "version": "1.0.0",
  "description": "Enterprise backend API",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "typeorm migration:run -d dist/database/data-source.js",
    "migrate:create": "typeorm migration:create",
    "seed": "ts-node src/database/seeds/index.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "typescript": "^5.2.0",
    "dotenv": "^16.3.1",
    "typeorm": "^0.3.17",
    "pg": "^8.11.2",
    "redis": "^4.6.11",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "uuid": "^9.0.0",
    "axios": "^1.6.0",
    "nodemailer": "^6.9.6",
    "winston": "^3.11.0",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/bcryptjs": "^2.4.2",
    "@types/uuid": "^9.0.2",
    "@types/jest": "^29.5.7",
    "ts-jest": "^29.1.1",
    "jest": "^29.7.0",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "jest-mock-extended": "^3.0.5"
  }
}
