# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a secure secret: openssl rand -base64 64
JWT_SECRET=replace-with-a-long-random-secret-at-least-256-bits
JWT_EXPIRATION_MS=86400000

# ─── Service Ports ────────────────────────────────────────────────────────────
BACKEND_PORT=8080
FRONTEND_PORT=3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api/v1
