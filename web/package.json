    "clsx": "^2.0.0",
    "date-fns": "^2.30.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.1.0",
    "vite": "^5.0.0",
    "typescript": "^5.2.0",
    "react-icons": "^4.12.0",
    "tailwindcss": "^3.3.0",
    "postcss": "^8.4.31",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.50.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "prettier": "^3.0.0",
    "vitest": "^0.34.0",
    "@vitest/ui": "^0.34.0",
